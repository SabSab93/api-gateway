generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  firstname String
  email     String   @unique
  password  String
  cats      Cat[]
  createdAt DateTime @default(now())
}

model Cat {
  id        Int      @id @default(autoincrement())
  name      String
  age       Int?
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  stays     Stay[]
}

model Room {
  id       Int    @id @default(autoincrement())
  name     String
  capacity Int
  stays    Stay[]
}

model Stay {
  id        Int      @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  catId     Int
  roomId    Int
  cat       Cat      @relation(fields: [catId], references: [id])
  room      Room     @relation(fields: [roomId], references: [id])
}
