generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  firstname String
  email     String     @unique
  password  String
  responses Response[]
  createdAt DateTime   @default(now())
}

model Qcm {
  id        Int        @id @default(autoincrement())
  name      String
  questions Question[]
  createdAt DateTime   @default(now())
}

model Question {
  id           Int           @id @default(autoincrement())
  description  String
  qcmId        Int
  qcm          Qcm           @relation(fields: [qcmId], references: [id], onDelete: Cascade)
  propositions Proposition[]
}

model Proposition {
  id          Int        @id @default(autoincrement())
  description String
  isValid     Boolean
  questionId  Int
  question    Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responses   Response[]
}

model Response {
  propositionId Int
  userId        Int
  proposition   Proposition @relation(fields: [propositionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  isChecked     Boolean

  @@id([propositionId, userId])
}
